# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://finparse_user:finparse_pass@localhost:5432/finparse
DATABASE_URL_SYNC=postgresql+psycopg2://finparse_user:finparse_pass@localhost:5432/finparse

POSTGRES_DB=finparse
POSTGRES_USER=finparse_user
POSTGRES_PASSWORD=finparse_pass
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
API_PORT=8000
APP_NAME="FinParse API"
APP_VERSION="1.0.0"

# ── File Storage ───────────────────────────────────────────────────────────────
STORAGE_BACKEND=local             # local | s3 | gcs
STORAGE_PATH=./uploads            # for local backend
# AWS_S3_BUCKET=your-bucket
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=us-east-1

# ── File Limits ─────────────────────────────────────────────────────────────────
MAX_PDF_SIZE_MB=50
MAX_CSV_SIZE_MB=25
MAX_PDF_PAGES=200
MAX_CSV_ROWS=100000

# ── CSV Parser ──────────────────────────────────────────────────────────────────
CSV_CHUNK_SIZE=1000               # rows to process per chunk
CSV_MIN_TEXT_CONFIDENCE=0.3       # below this, mark as partial

# ── PDF Parser ──────────────────────────────────────────────────────────────────
PDF_MIN_TEXT_PER_PAGE=50          # chars below this = scanned page
# PDF passwords are NEVER stored — passed at runtime only

# ── Celery ──────────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=2
